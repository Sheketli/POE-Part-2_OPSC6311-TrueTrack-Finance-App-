<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/divider"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivDragHandle"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_drag_dots"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/text_secondary" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_cat_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            app:cardBackgroundColor="@color/forest_green_light"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivDragHandle"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvCategoryEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🛒"
                android:textSize="20sp" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvCategoryName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Groceries"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/tvPercentage"
            app:layout_constraintStart_toEndOf="@id/card_cat_icon"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvPercentage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text="71%"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tvCategoryName"
            app:layout_constraintEnd_toStartOf="@id/btnRenameCategory"
            app:layout_constraintTop_toTopOf="@id/tvCategoryName" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressBarCategory"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:progress="71"
            app:indicatorColor="@color/forest_green"
            app:layout_constraintEnd_toEndOf="@id/tvPercentage"
            app:layout_constraintStart_toStartOf="@id/tvCategoryName"
            app:layout_constraintTop_toBottomOf="@id/tvCategoryName"
            app:trackColor="@color/forest_green_light"
            app:trackCornerRadius="4dp"
            app:trackThickness="6dp" />

        <TextView
            android:id="@+id/tvSpentLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Spent:"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@id/tvCategoryName"
            app:layout_constraintTop_toBottomOf="@id/progressBarCategory" />

        <TextView
            android:id="@+id/tvSpent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="R1,420"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tvSpentLabel"
            app:layout_constraintStart_toEndOf="@id/tvSpentLabel"
            app:layout_constraintTop_toTopOf="@id/tvSpentLabel" />

        <TextView
            android:id="@+id/tvLimitLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Limit:"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/tvSpentLabel"
            app:layout_constraintEnd_toStartOf="@id/tvLimit"
            app:layout_constraintTop_toTopOf="@id/tvSpentLabel" />

        <TextView
            android:id="@+id/tvLimit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="R2,000"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tvLimitLabel"
            app:layout_constraintEnd_toEndOf="@id/progressBarCategory"
            app:layout_constraintTop_toTopOf="@id/tvLimitLabel" />

        <ImageView
            android:id="@+id/btnRenameCategory"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_edit"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvCategoryName"
            app:tint="@color/text_secondary" />

        <ImageView
            android:id="@+id/btnDeleteCategory"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_delete"
            app:layout_constraintBottom_toBottomOf="@id/tvSpent"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="@color/danger" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
