<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TrueTrackFinance" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary Palette -->
        <item name="colorPrimary">@color/forest_green</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/forest_green_light</item>
        <item name="colorOnPrimaryContainer">@color/forest_green_dark</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/forest_green</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background & Surface -->
        <item name="android:colorBackground">@color/background_light</item>
        <item name="colorSurface">@color/surface_light</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/forest_green</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Custom Styles -->
    <style name="Widget.TrueTrack.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">2dp</item>
        <item name="android:layout_margin">8dp</item>
    </style>

    <style name="Widget.TrueTrack.Button" parent="Widget.Material3.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.TrueTrack.EditText" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/input_background</item>
        <item name="boxCornerRadiusTopStart">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/input_corner_radius</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
        <item name="hintEnabled">false</item>
    </style>

    <style name="Theme.TrueTrackFinance.Splash" parent="Theme.TrueTrackFinance">
        <item name="android:windowBackground">@color/forest_green</item>
        <item name="android:statusBarColor">@color/forest_green</item>
        <item name="android:navigationBarColor">@color/forest_green</item>
    </style>

    <style name="BottomNavText" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Splash Screen theme (modern API) -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/forest_green</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.TrueTrackFinance</item>
    </style>
</resources>
